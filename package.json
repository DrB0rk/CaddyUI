{
  "name": "caddy-ui",
  "version": "0.2.2-dev-api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite --host 0.0.0.0\" \"node server/index.js\"",
    "dev:client": "vite --host 0.0.0.0",
    "dev:server": "node server/index.js",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "start": "NODE_ENV=production node server/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@monaco-editor/react": "4.7.0",
    "@vitejs/plugin-react": "6.0.1",
    "bcryptjs": "3.0.3",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "express": "5.2.1",
    "jsonwebtoken": "9.0.3",
    "lucide-react": "1.14.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "vite": "8.0.10"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "concurrently": "9.2.1",
    "typescript": "6.0.3"
  },
  "overrides": {
    "dompurify": "^3.4.2"
  }
}
