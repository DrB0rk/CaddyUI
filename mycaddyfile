erp.polderlabs.io {
	reverse_proxy http://10.0.2.171:8080 {
		header_up Host {host}
		header_up X-Forwarded-Host {host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Forwarded-For {remote_host}
	}
}

polderlabs.io {
	import borklab_tls
	reverse_proxy 10.0.2.201:3000 {
