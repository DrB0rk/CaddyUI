# =============================================================================
# SHARED SNIPPETS
# =============================================================================

(pass_host_header) {
	header_up Host {http.request.host}
}

(strip_identity_headers) {
	# Remove any spoofable identity headers from the client request.
	header -Remote-User
	header -Remote-Groups
	header -Remote-Name
	header -Remote-Email

	# Optional: also strip common alternative names if you ever used them.
	header -X-Auth-User
	header -X-Auth-Groups
	header -X-Auth-Name
	header -X-Auth-Email
}

(authelia_auth) {
	forward_auth http://10.0.2.83:9091 {
		uri /api/authz/forward-auth

		# Pass identity headers to upstream apps
		copy_headers Remote-User Remote-Groups Remote-Name Remote-Email

		# Ensure Authelia sees the correct request context
		header_up Host {http.request.host}
		header_up X-Forwarded-Host {http.request.host}
		header_up X-Forwarded-Proto {http.request.scheme}
		header_up X-Forwarded-Method {http.request.method}
		header_up X-Forwarded-Uri {http.request.uri}

		# Optional (Cloudflare): give Authelia the real client IP
		header_up X-Forwarded-For {http.request.header.CF-Connecting-IP}
	}
}

# Use this variant for polderlabs.io apps; it avoids Cloudflare-only headers
# and pins the Authelia portal URL to the same cookie scope.
(authelia_auth_polderlabs) {
	forward_auth http://10.0.2.83:9091 {
		uri /api/authz/forward-auth?authelia_url=https://auth.polderlabs.io/
		copy_headers Remote-User Remote-Groups Remote-Name Remote-Email

		# Keep forwarded context explicit and always valid.
		header_up Host {http.request.host}
		header_up X-Forwarded-Host {http.request.host}
		header_up X-Forwarded-Proto {http.request.scheme}
		header_up X-Forwarded-Method {http.request.method}
		header_up X-Forwarded-Uri {http.request.uri}
		header_up X-Forwarded-For {remote_host}
	}
}

(borklab_tls) {
	tls /etc/caddy/certs/borklab.cert /etc/caddy/certs/borklab.key
}

